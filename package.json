{
	"name": "@firefoxic/utils",
	"description": "Collection of useful utilities for JavaScript and Node.js.",
	"version": "2.1.1",
	"license": "MIT",
	"author": {
		"name": "Sergey Artemov",
		"email": "firefoxic.dev@gmail.com"
	},
	"homepage": "https://github.com/firefoxic/utils#readme",
	"bugs": {
		"url": "https://github.com/firefoxic/utils/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/firefoxic/utils.git"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"./dist/"
	],
	"engines": {
		"node": ">=22.18"
	},
	"scripts": {
		"help": "make help"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=26.4",
			"onFail": "download"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.9",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"@firefoxic/oxlint-config": "^0.4.0",
		"@types/node": "^26.1.0",
		"oxlint": "^1.72.0",
		"tsdown": "^0.22.3",
		"typescript": "^7.0.1-rc"
	},
	"keywords": [
		"javascript",
		"node.js",
		"prepare",
		"utils"
	]
}
