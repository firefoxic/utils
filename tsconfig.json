{
	"compilerOptions": {
		"target": "esnext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": [
			"ESNext",
		],
		"types": [
			"node"
		],
		"outDir": "./dist",
		"rootDir": "./src",
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"declaration": true,
		"noEmitOnError": true,
		"resolveJsonModule": true,
		"isolatedDeclarations": true
	},
	"include": [
		"src/**/*",
	],
	"exclude": [
		"dist",
		"node_modules",
	]
}
